{
  "name": "fxxk-frontned-hooks",
  "version": "0.1.3",
  "type": "commonjs",
  "bin": {
    "fooks": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:integration": "npm run build && node --test test/*.test.mjs",
    "bench:cache": "npm run build && node scripts/benchmark-cache.mjs",
    "clean": "rm -rf dist",
    "bench": "npm run build && node benchmarks/scripts/run-all.mjs",
    "bench:scan": "npm run build && node benchmarks/scripts/scan-cache.mjs",
    "bench:process-model": "npm run build && node benchmarks/scripts/process-model-probe.mjs",
    "bench:extract": "npm run build && node benchmarks/scripts/extract.mjs",
    "bench:stability": "npm run build && node benchmarks/scripts/stability.mjs",
    "bench:layer2:applied:selftest": "npm run build && node benchmarks/layer2-frontend-task/validate-r4-applied.js --root=benchmarks/layer2-frontend-task/fixtures/r4-applied-pass/combobox --output=benchmarks/layer2-frontend-task/results/R4-applied-acceptance-validator-self-test-2026-04-21.json",
    "bench:gate": "npm run build && node benchmarks/scripts/gate.mjs",
    "lint": "npm run typecheck -- --pretty false",
    "smoke:claude": "npm run build && node scripts/smoke-claude-hook.mjs",
    "smoke:domain-detector": "npm run build && node dist/cli/index.js inspect-domain test/fixtures/frontend-domain-expectations/webview-boundary-basic.tsx --json",
    "release:smoke": "npm run build && node scripts/release-smoke.mjs",
    "bench:layer2:r4:repeated": "npm run build && node benchmarks/layer2-frontend-task/run-r4-repeated.js",
    "bench:layer2:provider-cost": "node benchmarks/layer2-frontend-task/run-provider-cost-evidence.js",
    "bench:layer2:provider-cost:repeated": "node benchmarks/layer2-frontend-task/run-provider-cost-repeated.js",
    "bench:layer2:provider-cost:corrected-manifest": "npm run build && node benchmarks/layer2-frontend-task/build-provider-cost-corrected-manifest.js",
    "bench:layer2:billing-import": "node benchmarks/layer2-frontend-task/billing-import-evidence.js",
    "branch:audit": "node scripts/audit-remote-branches.mjs",
    "ci:alerts": "node scripts/triage-ci-alerts.mjs",
    "pr:alerts": "node scripts/guard-pr-alerts.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2"
  },
  "description": "Frontend context compression CLI for React/TSX projects; npm package fxxk-frontned-hooks installs the fooks command.",
  "main": "dist/index.js",
  "files": [
    "dist",
    "docs/setup.md",
    "docs/release.md",
    "docs/roadmap.md",
    "docs/rn-webview-architecture.md",
    "docs/usage-log-boundary.md",
    "docs/provider-tokenizer-boundary.md",
    "docs/lsp-extraction-boundary.md",
    "docs/runtime-bridge-contract.md",
    "docs/codex-live-feedback-checklist.md",
    "docs/opencode-read-interception.md",
    "docs/language-core-strategy.md",
    "docs/CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minislively/fooks.git"
  },
  "bugs": {
    "url": "https://github.com/minislively/fooks/issues"
  },
  "homepage": "https://github.com/minislively/fooks#readme",
  "dependencies": {
    "typescript": "^5.9.2"
  },
  "author": "minislively",
  "keywords": [
    "codex",
    "cli",
    "frontend",
    "context-compression",
    "react",
    "tsx",
    "typescript",
    "jsx"
  ],
  "private": false,
  "license": "MIT"
}
